# Core
DATABASE_URL=postgresql+psycopg://taxi:taxi@localhost:5432/taxi
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me
ENVIRONMENT=development

# Global provider mode default. Every external integration falls back to mock
# automatically if its API key is empty, even when set to "live" below.
PROVIDER_MODE=mock

# OpenAI (optional — leave blank to stay mocked)
OPENAI_PROVIDER_MODE=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Yandex Maps/Traffic (optional)
MAPS_PROVIDER_MODE=
YANDEX_MAPS_API_KEY=

# Weather (optional, OpenWeather-shaped)
WEATHER_PROVIDER_MODE=
OPENWEATHER_API_KEY=

# Flights (optional, AviationStack-shaped — daily schedule sync)
FLIGHTS_PROVIDER_MODE=
AVIATIONSTACK_API_KEY=

# Flights, real-time complement (optional, OpenSky Network OAuth2 client
# credentials — get a client_id/client_secret at opensky-network.org)
OPENSKY_PROVIDER_MODE=
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Metro incidents (optional — no known public API; placeholder)
METRO_PROVIDER_MODE=
METRO_API_KEY=

# Traffic (optional, TomTom Traffic Flow-shaped — free tier: 2,500 req/day)
TRAFFIC_PROVIDER_MODE=
TOMTOM_API_KEY=

# Public holidays (isDayOff.ru — genuinely free, no key needed at all; safe to
# set to "live" with zero cost the moment you want real Russian holiday dates
# instead of the hardcoded fallback list in app/synth/signal_config.py)
CALENDAR_PROVIDER_MODE=

# Real ride prices → live surge coefficient ("кэф") per district. Yandex Taxi
# widget API: clid + apikey are issued on request at https://yandex.ru/dev/taxi/
# (request limits agreed individually — tune PRICING_POLL_MINUTES to your
# budget: 130 districts per poll, so 30 min ≈ 6,240 req/day).
PRICING_PROVIDER_MODE=
YANDEX_TAXI_CLID=
YANDEX_TAXI_API_KEY=
PRICING_POLL_MINUTES=30

# Telegram bot
TELEGRAM_BOT_TOKEN=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
